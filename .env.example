# Database
DB_URL=postgresql+asyncpg://auth_user:auth_password@localhost:5432/auth
DB_TEST_URL=postgresql+asyncpg://auth_user:auth_password@localhost:5432/auth_test

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-to-a-long-random-secret-in-production

# Token expiry
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
RESET_TOKEN_EXPIRE_MINUTES=15

# App environment (development | production)
APP_ENV=development
